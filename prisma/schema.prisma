generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts Account[]
  sessions Session[]

  taskGroups            TaskGroup[]
  tasks                 Task[]
  taskCompletions       TaskCompletion[]
  taskSessions          TaskSession[]
  taskSubtasks          TaskSubtask[]
  subtaskCompletions    SubtaskCompletion[]
  downtimeSessions      DowntimeSession[]
  actionItems           ActionItem[]
  commitments           Commitment[]
  commitmentOccurrences CommitmentOccurrenceCompletion[]
  topics                Topic[]
  dailyChecks           DailyCheck[]
  dailyCheckResults     DailyCheckResult[]
  dailyReviewDismissals DailyReviewDismissal[]
  challenges            Challenge[]
  dayStartOverride      DayStartOverride?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Task {
  id          String  @id @default(cuid())
  title       String
  description String?
  playbook    String?

  isMandatory Boolean @default(false)
  isActive    Boolean @default(true)

  missedCount Int @default(0)
  stackOrder  Int @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  groupId String?
  group   TaskGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  completions        TaskCompletion[]
  sessions           TaskSession[]
  subtasks           TaskSubtask[]
  subtaskCompletions SubtaskCompletion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskCompletion {
  id String @id @default(cuid())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  completedOn DateTime
  createdAt   DateTime @default(now())

  @@unique([taskId, completedOn])
  @@index([userId, completedOn])
}

model TaskSubtask {
  id    String @id @default(cuid())
  title String

  isActive   Boolean @default(true)
  stackOrder Int     @default(0)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  completions SubtaskCompletion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId, stackOrder])
  @@index([userId, isActive])
}

model SubtaskCompletion {
  id String @id @default(cuid())

  subtaskId String
  subtask   TaskSubtask @relation(fields: [subtaskId], references: [id], onDelete: Cascade)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  completedOn DateTime
  createdAt   DateTime @default(now())

  @@unique([subtaskId, completedOn])
  @@index([taskId, completedOn])
  @@index([userId, completedOn])
}

model TaskGroup {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskSession {
  id String @id @default(cuid())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  day       DateTime
  startedAt DateTime
  stoppedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, day])
  @@index([userId, stoppedAt])
  @@index([taskId, day])
}

model DowntimeSession {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category  String
  day       DateTime
  startedAt DateTime
  stoppedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, day])
  @@index([userId, stoppedAt])
}

model ActionItem {
  id          String  @id @default(cuid())
  title       String
  description String?
  playbook    String?

  dueOn       DateTime?
  completedAt DateTime?
  canceledAt  DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, dueOn])
  @@index([userId, completedAt])
  @@index([userId, canceledAt])
}

model Topic {
  id          String  @id @default(cuid())
  title       String
  category    String?
  description String?
  body        String?
  isArchived  Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isArchived, updatedAt])
  @@index([userId, category])
}

model Commitment {
  id          String  @id @default(cuid())
  title       String
  description String?
  playbook    String?
  location    String?

  day         DateTime
  startsAt    DateTime?
  endsAt      DateTime?
  completedAt DateTime?
  canceledAt  DateTime?

  recurrence          CommitmentRecurrence @default(NONE)
  recurrenceDayOfWeek Int?
  recurrenceDays      Int[]                @default([])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  occurrenceCompletions CommitmentOccurrenceCompletion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, day])
  @@index([userId, recurrence, recurrenceDayOfWeek])
  @@index([userId, startsAt])
  @@index([userId, completedAt])
  @@index([userId, canceledAt])
}

model CommitmentOccurrenceCompletion {
  id String @id @default(cuid())

  commitmentId String
  commitment   Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  occurrenceDay DateTime
  completedAt   DateTime @default(now())

  @@unique([commitmentId, occurrenceDay])
  @@index([userId, occurrenceDay])
}

enum CommitmentRecurrence {
  NONE
  WEEKLY
}

enum DailyCheckStatus {
  YES
  NO
  SKIP
  UNSURE
}

model DailyCheck {
  id          String  @id @default(cuid())
  title       String
  description String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  results DailyCheckResult[]
  challenge Challenge?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive, sortOrder])
}

model Challenge {
  id           String  @id @default(cuid())
  title        String
  description  String?
  startDay     DateTime
  durationDays Int
  isActive     Boolean @default(true)

  dailyCheckId String     @unique
  dailyCheck   DailyCheck @relation(fields: [dailyCheckId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive, startDay])
}

model DailyCheckResult {
  id String @id @default(cuid())

  dailyCheckId String
  dailyCheck   DailyCheck @relation(fields: [dailyCheckId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetDay DateTime
  status    DailyCheckStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dailyCheckId, targetDay])
  @@index([userId, targetDay])
  @@index([status, targetDay])
}

model DailyReviewDismissal {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetDay   DateTime
  dismissedAt DateTime @default(now())

  @@unique([userId, targetDay])
  @@index([userId, dismissedAt])
}

model DayStartOverride {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  baseDay   DateTime
  targetDay DateTime
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}
